CREATE DATABASE PRACTICAL3;
USE PRACTICAL3;
CREATE TABLE STUDENT(ROLL_NO INT PRIMARY KEY,NAME VARCHAR(50),DEPT VARCHAR(50),MARKS INT,CITY VARCHAR(20));
INSERT INTO STUDENT VALUES
(1,"AMIT","COMP",85,"PUNE"),
(2,"AJAY","COMP",90,"PUNE"),
(3,"RIYA","IT",72,"MUMBAI"),
(4,"RAHUL","IT",75,"NASHIK"),
(5,"PRIYA","ENTC",65,"MUMBAI"),
(6,"RAJ","CIVIL",50,"SOLAPUR");
SELECT * FROM STUDENT;
-- DML
UPDATE STUDENT SET MARKS=80 WHERE ROLL_NO=5;
SELECT * FROM STUDENT;
INSERT INTO STUDENT VALUES (7,"RAM","IT",98,"NAGPUR");
SELECT * FROM STUDENT;
DELETE FROM STUDENT WHERE ROLL_NO=7;
SELECT * FROM STUDENT;
-- ARITHMETIC
SELECT NAME,MARKS,MARKS+5 AS UPDATED_MARKS FROM STUDENT;
-- LOGICAL
SELECT * FROM STUDENT WHERE DEPT="COMP" AND CITY="PUNE";
SELECT * FROM STUDENT WHERE CITY="MUMBAI" OR  CITY="PUNE";
-- SET OPERATORS
SELECT NAME,CITY FROM STUDENT WHERE CITY="PUNE" UNION SELECT NAME , CITY FROM STUDENT WHERE CITY="MUMBAI";
-- PATTERN
SELECT * FROM STUDENT WHERE NAME LIKE"R%";
SELECT * FROM STUDENT WHERE NAME LIKE"a%";
SELECT * FROM STUDENT WHERE CITY LIKE "PUNE";
-- STRING
SELECT NAME,UPPER(NAME)AS UPPER_NAME FROM STUDENT;
SELECT NAME,LENGTH(NAME)AS LENGTH FROM STUDENT;
-- DCL
CREATE USER "USER123" IDENTIFIED BY "123";
GRANT SELECT,INSERT,UPDATE ON STUDENT TO USER123;
SHOW GRANTS FOR USER123;
REVOKE UPDATE ON PR9.STUDENT FROM USER123;
SHOW GRANTS FOR USER123;
-- ROLE
CREATE ROLE STUD;
GRANT SELECT,INSERT,UPDATE ON PR9.STUDENT TO STUD;
SET DEFAULT ROLE STUD TO USER123;
SHOW GRANTS FOR STUD;
SHOW GRANTS FOR USER123;
-- TCL
START TRANSACTION;
INSERT INTO STUDENT VALUES (7,"KARAN","COMP",82,"MUMBAI");
SELECT * FROM STUDENT;
COMMIT;
START TRANSACTION;
DELETE FROM STUDENT WHERE ROLL_NO=4;
SELECT * FROM STUDENT;
ROLLBACK;
SELECT * FROM STUDENT;
START TRANSACTION;
INSERT INTO STUDENT VALUES (8,"MANAS","IT",76,"PUNE");
SAVEPOINT SP1;
INSERT INTO STUDENT VALUES (9,"RONAK","IT",86,"PUNE");
SELECT * FROM STUDENT;
ROLLBACK TO SP1;
SELECT * FROM STUDENT;
ROLLBACK;
SELECT * FROM STUDENT;
