SELECT * FROM STUDENT;
SELECT DEPARTMENT,COUNT(NAME) FROM STUDENT GROUP BY DEPARTMENT;
SELECT DEPARTMENT,AVG(MARKS) FROM STUDENT GROUP BY DEPARTMENT;
SELECT SUBJECT,SUM(MARKS) FROM STUDENT GROUP BY SUBJECT;
SELECT SUBJECT,MAX(MARKS) AS HIGHEST_MARKS FROM STUDENT GROUP BY SUBJECT;
SELECT DEPARTMENT,COUNT(NAME) FROM STUDENT GROUP BY DEPARTMENT HAVING COUNT(NAME)>2;
